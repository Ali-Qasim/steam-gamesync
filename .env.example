# gamesync configuration. Copy this file to ".env" and fill in your values.
# The real .env is gitignored - NEVER commit your API key.

# Comma-separated list of folders to watch for games.
GAMES_DIRS=C:\Games,D:\Games

# Your SteamGridDB API key (https://www.steamgriddb.com/profile/preferences).
# Required for artwork. Leave blank to skip artwork entirely.
STEAMGRIDDB_KEY=

# Path to the steamgrid CLI (https://github.com/boppreh/steamgrid/releases).
STEAMGRID_EXE=D:\steamgrid_windows\steamgrid.exe

# Steam install path. Leave blank to auto-detect from the registry.
STEAM_PATH=

# Steam userdata account id. "auto" picks the most-recently logged-in account.
USERDATA_ID=auto

# Steam category/collection that managed shortcuts are tagged with.
STEAM_TAG=GameSync

# Show a desktop toast when a game is added/removed (needs windows-toasts).
NOTIFICATIONS=false

# Restart Steam to apply changes when it is open but no game is running.
RESTART_STEAM_WHEN_IDLE=true

# Tuning.
DEBOUNCE_SECONDS=45
PERIODIC_CHECK_MINUTES=3
STEAMGRID_TIMEOUT_SECONDS=300

# Comma-separated folder names to ignore inside the games dirs.
SKIP_FOLDERS=_CommonRedist,.claude

# --- Apollo / Vibepollo launch-tile sync (optional) ---
# Mirror managed games into an Apollo/Vibepollo (Sunshine fork) apps.json as
# launch tiles, reusing the Steam grid cover art. Only touches gamesync's own
# tiles; your Desktop/Steam/manual tiles are left alone. Auto-skips if no
# apps.json is found, so this is a no-op on machines without Apollo.
APOLLO_SYNC=true

# Path to apps.json. Leave blank to auto-detect the usual Apollo/Vibepollo spots.
APOLLO_APPS=

# Base URL of the Apollo web UI, used to hot-reload the app list (no restart).
APOLLO_URL=https://localhost:47990

# Scoped API token so the watcher can trigger a live reload after writing tiles.
# Generate one in the Apollo web UI (API Tokens page), scoped to:
#     POST /api/apps/reorder
# Without a token the tiles are still written, but you must reload manually
# (Apollo tray -> "Reload Apps"). Keep this secret; it lives only in .env.
APOLLO_REORDER_TOKEN=
